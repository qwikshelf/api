# QwikShelf Beta Environment configuration
# Use these values specifically for the Beta stack

# Database configuration
DB_USER=qwikshelf
DB_PASSWORD=beta_secret_pass
DB_NAME=qwikshelf_beta

# Backend configuration
JWT_SECRET=beta_jwt_supersecret
ALLOWED_ORIGINS=http://localhost:5174,http://beta.qwikshelf.store

# This port is internal to the Docker host
PORT=8080
